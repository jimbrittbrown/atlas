# Frontend runtime settings
VITE_ATLAS_API_BASE_URL=/atlas-api
VITE_ATLAS_REQUEST_TIMEOUT_MS=8000
VITE_ATLAS_STALE_AFTER_MINUTES=20
VITE_ATLAS_ENABLE_FIXTURES=false
VITE_ATLAS_DASHBOARD_ROLE=CEO

# Optional: start dashboard in CUSTOMER role for portal-focused local testing
# VITE_ATLAS_DASHBOARD_ROLE=CUSTOMER

# Backend gateway auth token for local dev (set in shell before npm run dev)
# export ATLAS_DASHBOARD_API_TOKEN=<your_token>

# Customer auth defaults to secure cookie transport.
# Enable header session token transport only for explicit non-production fallback testing.
# VITE_ATLAS_CUSTOMER_HEADER_SESSION_TRANSPORT=false

# Customer CSRF token cookie/header names must align with backend settings.
VITE_ATLAS_CUSTOMER_CSRF_COOKIE_NAME=atlas_customer_csrf
VITE_ATLAS_CUSTOMER_CSRF_HEADER_NAME=x-atlas-csrf-token
