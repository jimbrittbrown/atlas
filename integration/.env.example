# Atlas integration identity and session configuration
# Provider selection: local (development), oidc (external provider)
ATLAS_IDENTITY_PROVIDER=local

# Block local development provider in production/staging unless emergency override
ATLAS_AUTH_ALLOW_DEVELOPMENT_IN_PRODUCTION=false
ATLAS_LOCAL_IDENTITY_AUTO_VERIFY=true

# Session security controls
ATLAS_AUTH_SESSION_IDLE_TIMEOUT_MS=1800000
ATLAS_AUTH_SESSION_ABSOLUTE_TIMEOUT_MS=43200000
ATLAS_AUTH_SESSION_PEPPER=replace-with-secure-random-value

# Customer authentication transport
ATLAS_CUSTOMER_AUTH_TRANSPORT_MODE=secure_cookie
ATLAS_CUSTOMER_AUTH_ALLOW_DEVELOPMENT_TOKEN_TRANSPORT=false
ATLAS_CUSTOMER_SESSION_COOKIE_NAME=atlas_customer_session
ATLAS_CUSTOMER_SESSION_COOKIE_PATH=/api/v1/customer
ATLAS_CUSTOMER_SESSION_COOKIE_SAMESITE=Lax
ATLAS_CUSTOMER_SESSION_COOKIE_SECURE=true
ATLAS_CUSTOMER_SESSION_COOKIE_HTTP_ONLY=true
ATLAS_CUSTOMER_SESSION_COOKIE_DOMAIN=

# Trusted customer browser origins for credentialed customer mutations.
# Exact origins only, comma-separated (no wildcard).
ATLAS_CUSTOMER_TRUSTED_ORIGINS=https://portal.atlas.example
ATLAS_CUSTOMER_ENFORCE_TRUSTED_ORIGIN=true
ATLAS_CUSTOMER_ALLOW_MISSING_ORIGIN=false

# CSRF double-submit token settings (customer cookie transport)
ATLAS_CUSTOMER_CSRF_PROTECTION_ENABLED=true
ATLAS_CUSTOMER_CSRF_COOKIE_NAME=atlas_customer_csrf
ATLAS_CUSTOMER_CSRF_HEADER_NAME=x-atlas-csrf-token
ATLAS_CUSTOMER_CSRF_COOKIE_PATH=/api/v1/customer
ATLAS_CUSTOMER_CSRF_COOKIE_SAMESITE=Lax
ATLAS_CUSTOMER_CSRF_COOKIE_SECURE=true
ATLAS_CUSTOMER_CSRF_COOKIE_DOMAIN=

# OIDC provider settings (required when ATLAS_IDENTITY_PROVIDER=oidc)
ATLAS_IDENTITY_OIDC_ISSUER_URL=
ATLAS_IDENTITY_OIDC_CLIENT_ID=
ATLAS_IDENTITY_OIDC_CLIENT_SECRET=
ATLAS_IDENTITY_OIDC_AUDIENCE=
ATLAS_IDENTITY_OIDC_MANAGEMENT_TOKEN=

# Dashboard API role tokens (service auth)
ATLAS_DASHBOARD_API_TOKEN=
ATLAS_DASHBOARD_API_TOKEN_CUSTOMER=
