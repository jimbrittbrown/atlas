  "pipeline": [
    {
      "order": 1,
      "stage": "PROSPECT",
      "entryCriteria": "Target account is identified with decision-maker signal.",
      "exitCriteria": "Prospect record created in CRM.",
      "owner": "Prospect Intelligence Lead"
    },
    {
      "order": 2,
      "stage": "QUALIFIED_PROSPECT",
      "entryCriteria": "Fit score exceeds qualification threshold.",
      "exitCriteria": "Qualification score and rationale logged.",
      "owner": "Sales Qualification Lead"
    },
    {
      "order": 3,
      "stage": "AUDIT",
      "entryCriteria": "Prospect has qualification evidence and contact path.",
      "exitCriteria": "Audit output delivered and referenced in outreach.",
      "owner": "Audit Specialist"
    },
    {
      "order": 4,
      "stage": "OUTREACH",
      "entryCriteria": "Audit completed and outreach hypothesis approved.",
      "exitCriteria": "Prospect response state recorded.",
      "owner": "Outreach Specialist"
    },
    {
      "order": 5,
      "stage": "MEETING",
      "entryCriteria": "Prospect positively engages and books conversation.",
      "exitCriteria": "Meeting notes captured and next action assigned.",
      "owner": "Sales Closer"
    },
    {
      "order": 6,
      "stage": "PROPOSAL",
      "entryCriteria": "Discovery notes and offer recommendation are complete.",
      "exitCriteria": "Proposal status set to accepted/rejected.",
      "owner": "Revenue Operations Lead"
    },
    {
      "order": 7,
      "stage": "CLOSED_WON_OR_CLOSED_LOST",
      "entryCriteria": "Proposal decision deadline reached.",
      "exitCriteria": "Revenue outcome and reason code captured.",
      "owner": "Executive Sales Manager"
    },
    {
      "order": 8,
      "stage": "PROJECT_DELIVERY",
      "entryCriteria": "Closed Won and commercial documents completed.",
      "exitCriteria": "Delivery handoff accepted by operating company.",
      "owner": "Operating Company Delivery Lead"
    },
    {
      "order": 9,
      "stage": "CUSTOMER_SUCCESS",
      "entryCriteria": "Initial delivery milestone achieved.",
      "exitCriteria": "Satisfaction measurement completed.",
      "owner": "Customer Success Lead"
    },
    {
      "order": 10,
      "stage": "REFERRAL",
      "entryCriteria": "Satisfaction threshold met and referral ask triggered.",
      "exitCriteria": "Referral accepted/declined captured.",
      "owner": "Growth Partnerships Lead"
    },
    {
      "order": 11,
      "stage": "REPEAT_BUSINESS",
      "entryCriteria": "Customer has active expansion opportunity.",
      "exitCriteria": "Expansion deal opened or customer retained in nurture loop.",
      "owner": "Account Expansion Lead"
    }
